DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TEMPERATURE=0
AGENT_MAX_TASKS=5

# Optional realtime web search for Agent web_search tasks.
# Supported providers in this project: exa_mcp, tavily, mock.
WEB_SEARCH_PROVIDER=
WEB_SEARCH_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=10
WEB_SEARCH_DEPTH=basic
WEB_SEARCH_EXA_MCP_ENDPOINT=https://mcp.exa.ai/mcp
WEB_SEARCH_EXA_TOOL_NAME=web_search_exa

# Optional web_fetch tool limits.
WEB_FETCH_TIMEOUT_SECONDS=10
WEB_FETCH_MAX_BYTES=1048576
WEB_FETCH_MAX_CHARS=12000
WEB_FETCH_MAX_REDIRECTS=3
WEB_FETCH_USER_AGENT=local-rag-web-fetch/1.0

# Optional weather_query tool.
# Default provider open_meteo does not require an API key.
WEATHER_QUERY_PROVIDER=open_meteo
WEATHER_QUERY_TIMEOUT_SECONDS=10
WEATHER_QUERY_MAX_FORECAST_DAYS=16
WEATHER_QUERY_DEFAULT_LOCATION=桂林
OPEN_METEO_GEOCODING_ENDPOINT=https://geocoding-api.open-meteo.com/v1/search
OPEN_METEO_FORECAST_ENDPOINT=https://api.open-meteo.com/v1/forecast

# Optional map_route tool. Supported providers: local, amap.
MAP_ROUTE_PROVIDER=local
MAP_ROUTE_DEFAULT_MODE=taxi
MAP_ROUTE_DEFAULT_ORIGIN=
MAP_ROUTE_DEFAULT_VISIT_DURATION_MIN=90
MAP_ROUTE_MAX_EXACT_PLACES=8
MAP_ROUTE_ROAD_FACTOR=1.25
AMAP_API_KEY=
AMAP_DEFAULT_CITY=桂林
AMAP_TIMEOUT_SECONDS=10

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

EMBEDDING_MODEL_PATH=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RERANKER_MODEL_PATH=BAAI/bge-reranker-base
MODEL_DEVICE=cpu

CACHE_BACKEND_TYPE=hybrid
CACHE_BASE_DIR=.cache
CACHE_DEFAULT_TTL=86400
CACHE_MAX_MEMORY_ITEMS=1000
CACHE_ENABLE_VECTOR=true
CACHE_SIMILARITY_THRESHOLD=0.9
