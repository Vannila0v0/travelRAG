    {
      "name": "guilin_city_day_plan",
      "description": "桂林市区一日游规划，包含交通、票价和餐饮补充信息。",
      "match": {
        "all": [
          {
            "any": ["桂林市区", "桂林", "市区"]
          },
          {
            "any": ["一天", "一日游"]
          },
          {
            "any": ["交通", "票价", "门票", "价格", "预算"]
          }
        ],
        "not": ["晚上", "夜游", "夜间", "桂林千古情", "千古情"]
