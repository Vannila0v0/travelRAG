        {
          "task_id": "task_002",
          "task_type": "local_search",
          "description": "查询象鼻山、靖江王府、两江四湖、日月双塔等核心景点的门票价格、开放时间和建议游玩时长。",
          "priority": 1,
          "depends_on": ["task_001"],
          "entities": ["象鼻山", "靖江王府", "两江四湖", "日月双塔"]
