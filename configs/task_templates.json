      "execution_mode": "parallel",
      "nodes": [
        {
          "task_id": "task_001",
          "task_type": "global_search",
          "description": "获取桂林市区核心景点和一日游路线框架，覆盖象鼻山、靖江王府、两江四湖、日月双塔等候选点。",
          "priority": 1,
          "depends_on": [],
          "entities": ["桂林市区", "核心景点"]
